# Muxingplus HA runtime configuration

# Unique cluster key used in DynamoDB lease table
HA_CLUSTER_ID=vpn-headend-prod

# Unique node ID for this host (must differ per node)
HA_NODE_ID=headend-a

# AWS region and lease table
HA_REGION=us-east-1
HA_DDB_TABLE=muxingplus_ha_leases

# Lease behavior
HA_LEASE_TTL_SEC=15
HA_LOOP_INTERVAL_SEC=3

# Optional EIP failover (set both to enable)
# HA_EIP_ALLOC_ID=eipalloc-xxxxxxxxxxxxxxxxx
# HA_ENI_ID=eni-xxxxxxxxxxxxxxxxx

# Service actions
HA_IPSEC_SERVICE=ipsec
HA_PROMOTE_START_SERVICES=""
HA_DEMOTE_STOP_SERVICES=""
HA_DEMOTE_STOP_IPSEC=true

# Flow-state sync layer:
#   none | conntrackd
FLOW_SYNC_MODE=conntrackd
HA_CONNTRACKD_SERVICE=conntrackd
HA_CONNTRACKD_COMMIT_ON_PROMOTE=true
HA_CONNTRACKD_RESYNC_ON_DEMOTE=true

# IPsec SA sync layer:
#   none | libreswan-no-sa-sync | strongswan-ha
SA_SYNC_MODE=libreswan-no-sa-sync
# If using strongswan-ha, render plugin config from:
#   /etc/muxingplus-ha/examples/ha-sync.env.example
# via:
#   render-strongswan-ha-conf.sh /etc/muxingplus-ha/ha-sync.env /etc/strongswan.d/charon/ha.conf

# Optional custom hook scripts
# HA_PROMOTE_HOOK=/usr/local/sbin/ha-custom-promote.sh
# HA_DEMOTE_HOOK=/usr/local/sbin/ha-custom-demote.sh

# State/log locations
HA_STATE_DIR=/run/muxingplus-ha
HA_LOG_FILE=/var/log/muxingplus-ha.log
