{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nekdatasoultions/muxingRPDB-Platform-Framework/muxer/config/schema/environment-bindings.schema.json",
  "title": "RPDB Environment Bindings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "environment"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "bindings"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bindings": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        },
        "backend_resolver": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "roles": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": {
                  "type": [
                    "string",
                    "number",
                    "boolean"
                  ]
                }
              }
            },
            "clusters": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": {
                    "type": [
                      "string",
                      "number",
                      "boolean"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
