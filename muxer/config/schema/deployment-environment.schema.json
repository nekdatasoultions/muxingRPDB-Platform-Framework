{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nekdatasoultions/muxingRPDB-Platform-Framework/muxer/config/schema/deployment-environment.schema.json",
  "title": "RPDB Deployment Environment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "environment",
    "targets",
    "datastores",
    "artifacts",
    "backups",
    "nat_t_watcher",
    "customer_requests",
    "owners"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "aws",
        "access",
        "live_apply"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "description": {
          "type": "string"
        },
        "aws": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "region"
          ],
          "properties": {
            "region": {
              "$ref": "#/$defs/non_empty_string"
            },
            "account_hint": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "access": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method"
          ],
          "properties": {
            "method": {
              "enum": [
                "ssm",
                "ssh",
                "staged"
              ]
            },
            "ssm": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "region": {
                  "$ref": "#/$defs/non_empty_string"
                },
                "document_name": {
                  "$ref": "#/$defs/non_empty_string"
                }
              }
            },
            "ssh": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "user": {
                  "$ref": "#/$defs/non_empty_string"
                },
                "key_ref": {
                  "$ref": "#/$defs/non_empty_string"
                }
              }
            }
          }
        },
        "live_apply": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "requires_approval"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "requires_approval": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "muxer",
        "headends"
      ],
      "properties": {
        "muxer": {
          "$ref": "#/$defs/target"
        },
        "headends": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "nat",
            "non_nat"
          ],
          "properties": {
            "nat": {
              "$ref": "#/$defs/headend_pair"
            },
            "non_nat": {
              "$ref": "#/$defs/headend_pair"
            }
          }
        }
      }
    },
    "datastores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "customer_sot_table",
        "allocation_table"
      ],
      "properties": {
        "mode": {
          "enum": [
            "dynamodb",
            "staged"
          ]
        },
        "customer_sot_table": {
          "$ref": "#/$defs/non_empty_string"
        },
        "allocation_table": {
          "$ref": "#/$defs/non_empty_string"
        },
        "staged_root": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bucket",
        "prefix"
      ],
      "properties": {
        "mode": {
          "enum": [
            "s3",
            "staged"
          ]
        },
        "bucket": {
          "$ref": "#/$defs/non_empty_string"
        },
        "prefix": {
          "$ref": "#/$defs/non_empty_string"
        },
        "staged_root": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "backups": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_root",
        "muxer",
        "nat_headend",
        "non_nat_headend"
      ],
      "properties": {
        "baseline_root": {
          "$ref": "#/$defs/non_empty_string"
        },
        "muxer": {
          "$ref": "#/$defs/non_empty_string"
        },
        "nat_headend": {
          "$ref": "#/$defs/non_empty_string"
        },
        "non_nat_headend": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "nat_t_watcher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "log_source",
        "state_root",
        "output_root",
        "package_root"
      ],
      "properties": {
        "log_source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "enum": [
                "file",
                "cloudwatch"
              ]
            },
            "path": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "state_root": {
          "$ref": "#/$defs/non_empty_string"
        },
        "output_root": {
          "$ref": "#/$defs/non_empty_string"
        },
        "package_root": {
          "$ref": "#/$defs/non_empty_string"
        },
        "automation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "requires_approval": {
              "type": "boolean"
            },
            "run_provisioning": {
              "type": "boolean"
            },
            "follow": {
              "type": "boolean"
            },
            "poll_interval_seconds": {
              "type": "number",
              "minimum": 1
            }
          }
        },
        "promotion": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "enum": [
                "deploy_only",
                "remove_reapply"
              ]
            },
            "skip_if_already_nat": {
              "type": "boolean"
            },
            "allow_direct_nat_apply_if_missing": {
              "type": "boolean"
            }
          }
        },
        "log_sync": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "enum": [
                "auto",
                "local_file",
                "ssh_muxer"
              ]
            },
            "local_copy": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        }
      }
    },
    "customer_requests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_roots",
        "blocked_customers"
      ],
      "properties": {
        "allowed_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "blocked_customers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        }
      }
    },
    "owners": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation",
        "rollback"
      ],
      "properties": {
        "validation": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rollback": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "rpdb_managed",
        "selector",
        "access"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "role": {
          "enum": [
            "muxer",
            "nat-headend",
            "non-nat-headend"
          ]
        },
        "rpdb_managed": {
          "const": true
        },
        "selector": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "enum": [
                "tag",
                "instance_id",
                "staged"
              ]
            },
            "key": {
              "$ref": "#/$defs/non_empty_string"
            },
            "value": {
              "$ref": "#/$defs/non_empty_string"
            },
            "private_ip": {
              "$ref": "#/$defs/ipv4"
            },
            "public_ip": {
              "$ref": "#/$defs/ipv4"
            },
            "eip_allocation_id": {
              "$ref": "#/$defs/non_empty_string"
            },
            "eip_association_id": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "access": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method"
          ],
          "properties": {
            "method": {
              "enum": [
                "ssm",
                "ssh",
                "staged"
              ]
            }
          }
        }
      }
    },
    "headend_pair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active",
        "standby"
      ],
      "properties": {
        "active": {
          "$ref": "#/$defs/target"
        },
        "standby": {
          "$ref": "#/$defs/target"
        }
      }
    },
    "ipv4": {
      "type": "string",
      "format": "ipv4"
    }
  }
}
