{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nekdatasoultions/muxingRPDB-Platform-Framework/muxer/config/schema/customer-source.schema.json",
  "title": "RPDB Customer Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "customer"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "customer": {
      "$ref": "#/$defs/customer"
    }
  },
  "$defs": {
    "cidr": {
      "type": "string",
      "pattern": "^[0-9]{1,3}(\\.[0-9]{1,3}){3}\\/[0-9]{1,2}$"
    },
    "host_cidr": {
      "type": "string",
      "pattern": "^[0-9]{1,3}(\\.[0-9]{1,3}){3}\\/32$"
    },
    "ipv4": {
      "type": "string",
      "pattern": "^[0-9]{1,3}(\\.[0-9]{1,3}){3}$"
    },
    "ip_or_cidr": {
      "anyOf": [
        {
          "$ref": "#/$defs/ipv4"
        },
        {
          "$ref": "#/$defs/cidr"
        }
      ]
    },
    "ipv4_cidr_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cidr"
      }
    },
    "host_cidr_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/host_cidr"
      }
    },
    "string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ipsec_initiation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "bidirectional",
            "headend_only",
            "customer_only",
            "responder_only"
          ]
        },
        "headend_can_initiate": {
          "type": "boolean"
        },
        "customer_can_initiate": {
          "type": "boolean"
        },
        "traffic_can_start_tunnel": {
          "type": "boolean"
        },
        "bring_up_on_apply": {
          "type": "boolean"
        },
        "swanctl_start_action": {
          "type": "string",
          "enum": [
            "none",
            "start",
            "trap",
            "trap|start",
            "start|trap"
          ]
        }
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mux_ip",
        "router_ip"
      ],
      "properties": {
        "mux_ip": {
          "$ref": "#/$defs/cidr"
        },
        "router_ip": {
          "$ref": "#/$defs/cidr"
        }
      }
    },
    "peer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_ip",
        "psk_secret_ref"
      ],
      "properties": {
        "public_ip": {
          "$ref": "#/$defs/ipv4"
        },
        "remote_id": {
          "type": "string",
          "minLength": 1
        },
        "psk_secret_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mark",
        "table",
        "tunnel_key",
        "interface",
        "overlay"
      ],
      "properties": {
        "mark": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]+$"
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ]
        },
        "table": {
          "type": "integer",
          "minimum": 1
        },
        "tunnel_key": {
          "type": "integer",
          "minimum": 1
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "tunnel_type": {
          "type": "string",
          "enum": [
            "gre",
            "ipip"
          ]
        },
        "tunnel_ttl": {
          "type": "integer",
          "minimum": 1,
          "maximum": 255
        },
        "tunnel_mtu": {
          "type": "integer",
          "minimum": 576,
          "maximum": 65535
        },
        "rpdb_priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32765
        },
        "overlay": {
          "$ref": "#/$defs/overlay"
        }
      }
    },
    "selectors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_subnets",
        "remote_subnets"
      ],
      "properties": {
        "local_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "remote_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "remote_host_cidrs": {
          "$ref": "#/$defs/ipv4_cidr_array"
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "cluster": {
          "type": "string",
          "minLength": 1
        },
        "assignment": {
          "type": "string",
          "minLength": 1
        },
        "underlay_ip": {
          "$ref": "#/$defs/ipv4"
        },
        "egress_source_ips": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ipv4"
          },
          "uniqueItems": true
        }
      }
    },
    "protocols": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "udp500": {
          "type": "boolean"
        },
        "udp4500": {
          "type": "boolean"
        },
        "esp50": {
          "type": "boolean"
        },
        "force_rewrite_4500_to_500": {
          "type": "boolean"
        }
      }
    },
    "natd_rewrite": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "initiator_inner_ip": {
          "$ref": "#/$defs/ipv4"
        }
      }
    },
    "dynamic_provisioning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "nat_t_auto_promote"
          ]
        },
        "initial_customer_class": {
          "type": "string",
          "enum": [
            "strict-non-nat"
          ]
        },
        "initial_backend_cluster": {
          "type": "string",
          "enum": [
            "non-nat"
          ]
        },
        "trigger": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "protocol": {
              "type": "string",
              "enum": [
                "udp"
              ]
            },
            "destination_port": {
              "type": "integer",
              "const": 4500
            },
            "require_initial_udp500_observation": {
              "type": "boolean"
            },
            "observation_window_seconds": {
              "type": "integer",
              "minimum": 1
            },
            "confirmation_packets": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "promotion": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "customer_class": {
              "type": "string",
              "enum": [
                "nat"
              ]
            },
            "backend_cluster": {
              "type": "string",
              "enum": [
                "nat"
              ]
            },
            "backend_assignment": {
              "type": "string",
              "minLength": 1
            },
            "backend_role": {
              "type": "string",
              "minLength": 1
            },
            "protocols": {
              "$ref": "#/$defs/protocols"
            }
          }
        }
      }
    },
    "ipsec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto": {
          "type": "string",
          "minLength": 1
        },
        "ike_version": {
          "type": "string",
          "enum": [
            "auto",
            "ikev1",
            "ikev2",
            "v1",
            "v2"
          ]
        },
        "local_id": {
          "type": "string",
          "minLength": 1
        },
        "remote_id": {
          "type": "string",
          "minLength": 1
        },
        "ike": {
          "type": "string",
          "minLength": 1
        },
        "esp": {
          "type": "string",
          "minLength": 1
        },
        "ike_policies": {
          "$ref": "#/$defs/string_array"
        },
        "esp_policies": {
          "$ref": "#/$defs/string_array"
        },
        "dpddelay": {
          "type": "string",
          "minLength": 1
        },
        "dpdtimeout": {
          "type": "string",
          "minLength": 1
        },
        "dpdaction": {
          "type": "string",
          "minLength": 1
        },
        "ikelifetime": {
          "type": "string",
          "minLength": 1
        },
        "lifetime": {
          "type": "string",
          "minLength": 1
        },
        "replay_protection": {
          "type": "boolean"
        },
        "pfs_required": {
          "type": "boolean"
        },
        "pfs_groups": {
          "$ref": "#/$defs/string_array"
        },
        "forceencaps": {
          "type": "boolean"
        },
        "mobike": {
          "type": "boolean"
        },
        "fragmentation": {
          "type": "boolean"
        },
        "clear_df_bit": {
          "type": "boolean"
        },
        "path_mtu": {
          "type": "integer",
          "minimum": 576,
          "maximum": 65535
        },
        "mark": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+\\/0x[0-9a-fA-F]+$"
        },
        "vti_interface": {
          "type": "string",
          "minLength": 1
        },
        "vti_routing": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "enum": [
                "yes",
                "no",
                "true",
                "false"
              ]
            }
          ]
        },
        "vti_shared": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "enum": [
                "yes",
                "no",
                "true",
                "false"
              ]
            }
          ]
        },
        "bidirectional_secret": {
          "type": "boolean"
        },
        "initiation": {
          "$ref": "#/$defs/ipsec_initiation"
        }
      }
    },
    "host_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "real_ip",
        "translated_ip"
      ],
      "properties": {
        "real_ip": {
          "$ref": "#/$defs/host_cidr"
        },
        "translated_ip": {
          "$ref": "#/$defs/host_cidr"
        }
      }
    },
    "post_ipsec_nat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "disabled",
            "netmap",
            "snat_pool",
            "explicit_map"
          ]
        },
        "mapping_strategy": {
          "type": "string",
          "enum": [
            "one_to_one",
            "explicit_host_map"
          ]
        },
        "translated_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "translated_source_ip": {
          "$ref": "#/$defs/ip_or_cidr"
        },
        "real_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "host_mappings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/host_mapping"
          }
        },
        "core_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "output_mark": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+\\/0x[0-9a-fA-F]+$"
        },
        "tcp_mss_clamp": {
          "type": "integer",
          "minimum": 500,
          "maximum": 65535
        },
        "route_via": {
          "$ref": "#/$defs/ipv4"
        },
        "route_dev": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "outside_nat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "disabled",
            "netmap",
            "explicit_map"
          ]
        },
        "mapping_strategy": {
          "type": "string",
          "enum": [
            "one_to_one",
            "explicit_host_map"
          ]
        },
        "translated_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "real_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "host_mappings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/host_mapping"
          }
        },
        "customer_sources": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "output_mark": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+\\/0x[0-9a-fA-F]+$"
        },
        "tcp_mss_clamp": {
          "type": "integer",
          "minimum": 500,
          "maximum": 65535
        },
        "route_via": {
          "$ref": "#/$defs/ipv4"
        },
        "route_dev": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "customer_class",
        "peer",
        "transport",
        "selectors"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "customer_class": {
          "type": "string",
          "enum": [
            "nat",
            "strict-non-nat"
          ]
        },
        "peer": {
          "$ref": "#/$defs/peer"
        },
        "transport": {
          "$ref": "#/$defs/transport"
        },
        "selectors": {
          "$ref": "#/$defs/selectors"
        },
        "backend": {
          "$ref": "#/$defs/backend"
        },
        "protocols": {
          "$ref": "#/$defs/protocols"
        },
        "natd_rewrite": {
          "$ref": "#/$defs/natd_rewrite"
        },
        "dynamic_provisioning": {
          "$ref": "#/$defs/dynamic_provisioning"
        },
        "ipsec": {
          "$ref": "#/$defs/ipsec"
        },
        "post_ipsec_nat": {
          "$ref": "#/$defs/post_ipsec_nat"
        },
        "outside_nat": {
          "$ref": "#/$defs/outside_nat"
        }
      }
    }
  }
}
