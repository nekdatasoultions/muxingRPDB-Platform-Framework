{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nekdatasoultions/muxingRPDB-Platform-Framework/muxer/config/schema/customer-source.schema.json",
  "title": "RPDB Customer Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "customer"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "customer": {
      "$ref": "#/$defs/customer"
    }
  },
  "$defs": {
    "cidr": {
      "type": "string",
      "pattern": "^[0-9]{1,3}(\\.[0-9]{1,3}){3}\\/[0-9]{1,2}$"
    },
    "ipv4": {
      "type": "string",
      "pattern": "^[0-9]{1,3}(\\.[0-9]{1,3}){3}$"
    },
    "ip_or_cidr": {
      "anyOf": [
        {
          "$ref": "#/$defs/ipv4"
        },
        {
          "$ref": "#/$defs/cidr"
        }
      ]
    },
    "ipv4_cidr_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cidr"
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mux_ip",
        "router_ip"
      ],
      "properties": {
        "mux_ip": {
          "$ref": "#/$defs/cidr"
        },
        "router_ip": {
          "$ref": "#/$defs/cidr"
        }
      }
    },
    "peer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_ip",
        "psk_secret_ref"
      ],
      "properties": {
        "public_ip": {
          "$ref": "#/$defs/ipv4"
        },
        "remote_id": {
          "type": "string",
          "minLength": 1
        },
        "psk_secret_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mark",
        "table",
        "tunnel_key",
        "interface",
        "overlay"
      ],
      "properties": {
        "mark": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]+$"
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ]
        },
        "table": {
          "type": "integer",
          "minimum": 1
        },
        "tunnel_key": {
          "type": "integer",
          "minimum": 1
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "tunnel_type": {
          "type": "string",
          "enum": [
            "gre",
            "ipip"
          ]
        },
        "tunnel_ttl": {
          "type": "integer",
          "minimum": 1,
          "maximum": 255
        },
        "rpdb_priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32765
        },
        "overlay": {
          "$ref": "#/$defs/overlay"
        }
      }
    },
    "selectors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_subnets",
        "remote_subnets"
      ],
      "properties": {
        "local_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "remote_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "underlay_ip": {
          "$ref": "#/$defs/ipv4"
        }
      }
    },
    "protocols": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "udp500": {
          "type": "boolean"
        },
        "udp4500": {
          "type": "boolean"
        },
        "esp50": {
          "type": "boolean"
        },
        "force_rewrite_4500_to_500": {
          "type": "boolean"
        }
      }
    },
    "natd_rewrite": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "initiator_inner_ip": {
          "$ref": "#/$defs/ipv4"
        }
      }
    },
    "ipsec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto": {
          "type": "string",
          "minLength": 1
        },
        "local_id": {
          "type": "string",
          "minLength": 1
        },
        "remote_id": {
          "type": "string",
          "minLength": 1
        },
        "ike": {
          "type": "string",
          "minLength": 1
        },
        "esp": {
          "type": "string",
          "minLength": 1
        },
        "dpddelay": {
          "type": "string",
          "minLength": 1
        },
        "dpdtimeout": {
          "type": "string",
          "minLength": 1
        },
        "dpdaction": {
          "type": "string",
          "minLength": 1
        },
        "ikelifetime": {
          "type": "string",
          "minLength": 1
        },
        "lifetime": {
          "type": "string",
          "minLength": 1
        },
        "forceencaps": {
          "type": "boolean"
        },
        "mobike": {
          "type": "boolean"
        },
        "fragmentation": {
          "type": "boolean"
        },
        "mark": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+\\/0x[0-9a-fA-F]+$"
        },
        "vti_interface": {
          "type": "string",
          "minLength": 1
        },
        "vti_routing": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "enum": [
                "yes",
                "no",
                "true",
                "false"
              ]
            }
          ]
        },
        "vti_shared": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "enum": [
                "yes",
                "no",
                "true",
                "false"
              ]
            }
          ]
        },
        "bidirectional_secret": {
          "type": "boolean"
        }
      }
    },
    "post_ipsec_nat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "disabled",
            "netmap",
            "snat_pool"
          ]
        },
        "translated_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "translated_source_ip": {
          "$ref": "#/$defs/ip_or_cidr"
        },
        "real_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "core_subnets": {
          "$ref": "#/$defs/ipv4_cidr_array"
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "output_mark": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+\\/0x[0-9a-fA-F]+$"
        },
        "tcp_mss_clamp": {
          "type": "integer",
          "minimum": 500,
          "maximum": 65535
        },
        "route_via": {
          "$ref": "#/$defs/ipv4"
        },
        "route_dev": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "customer_class",
        "peer",
        "transport",
        "selectors"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "customer_class": {
          "type": "string",
          "enum": [
            "nat",
            "strict-non-nat"
          ]
        },
        "peer": {
          "$ref": "#/$defs/peer"
        },
        "transport": {
          "$ref": "#/$defs/transport"
        },
        "selectors": {
          "$ref": "#/$defs/selectors"
        },
        "backend": {
          "$ref": "#/$defs/backend"
        },
        "protocols": {
          "$ref": "#/$defs/protocols"
        },
        "natd_rewrite": {
          "$ref": "#/$defs/natd_rewrite"
        },
        "ipsec": {
          "$ref": "#/$defs/ipsec"
        },
        "post_ipsec_nat": {
          "$ref": "#/$defs/post_ipsec_nat"
        }
      }
    }
  }
}
